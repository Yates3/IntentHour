# Copy missing provider values into .dev.vars for local development.
# Add a fresh DeepSeek key locally. Never commit a real provider key.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:4317
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM=IntentHour <login@example.com>
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
PADDLE_API_BASE=https://sandbox-api.paddle.com
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
DEEPSEEK_API_KEY=
DEEPSEEK_REVIEW_MODEL=deepseek-v4-flash
